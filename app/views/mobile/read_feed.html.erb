<title><%= @subscription.feed.title %> - Fastladder Mobile</title>
<link href='https://unpkg.com/sakura.css/css/sakura.css' media='screen' rel='stylesheet' type='text/css'>
<meta content='width=320, initial-scale=1.0, maximum-scale=1.0, user-scalable=no' name='viewport'>
<%= csrf_meta_tags %>
<%= javascript_importmap_tags %>

<div data-controller="keyboard-nav" data-keyboard-nav-initial-value="item-<%= params[:item_id].to_i %>">
<h1>
  <a href="/mobile">
    <img src="/img/logo_small.gif" alt="Fastladder">
  </a>
</h1>
<h2><%= @subscription.feed.title %></h2>
<% @items.each do |item| %>
  <div class="item" id="item-<%= item.id %>" data-keyboard-nav-target="item">
    <h3>
      <a class="read" href="<%= item.link %>" target="_blank"><%= item.title %></a>
    </h3>

    <div><%= raw remove_style_attr_of_all_tags(item.body) %></div>
    <div>
      <p class="smallgrey">
        <a class="pin" href="/mobile/<%= item.id %>/pin"
           data-controller="pin"
           data-action="click->pin#create">Pin</a>
        Created: <%= item.created_on.localtime %>
      </p>
    </div>
    <hr>
  </div>
<% end %>

<div>
  <a id="next" href="/mobile/<%= @subscription.id %>/read?timestamp=<%= @items.last.updated_on.to_i %>"
     data-keyboard-nav-target="next"
     data-controller="mark-read"
     data-action="click->mark-read#submit">
    <button style="font-size: 1.5em;">Mark as read</button>
  </a>
</div>
</div>

<div style="height:2000px"></div>
<style>
  .smallgrey {
    font-size: 0.8em;
    color: #666;
  }
</style>
