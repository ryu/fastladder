<div id="content">
  <h2>Account</h2>
  <%= render "navi" %>
  <div class="account_form">
    <h4>Set API Auth Key</h4>
    <% if @member.auth_key %>
      <div data-controller="clipboard" style="margin-bottom: 1em">
        <p style="margin-bottom: 0.5em">Your API Auth Key is:</p>
        <div style="display: flex; align-items: center; gap: 0.5em">
          <input type="text" value="<%= @member.auth_key %>" readonly data-clipboard-target="source" style="font-family: monospace; padding: 0.5em; width: 280px; background: #f5f5f5; border: 1px solid #ddd">
          <button type="button" data-action="clipboard#copy" data-clipboard-success-text="Copied!" style="padding: 0.5em 1em; cursor: pointer">Copy</button>
        </div>
      </div>
    <% end %>
    <p>
      <%= form_for :account do |f| %>
        <%= f.submit 'Set or Change Auth Key' %>
      <% end %>
    </p>
  </div>
</div>
