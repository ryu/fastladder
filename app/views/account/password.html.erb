<%= flash[:error] %>
<div id="content">
	<h2>Account</h2>
	<%= render "navi" %>
	<div class="account_form">
	<h4>Change password</h4>
	<p>Your password must be at least 5 characters in length, and should not easily be guessed by other people.</p>
	<%= form_for :account, html: { data: { controller: "password-match form-validation", action: "submit->form-validation#validate" } } do |f| %>
		<dl>
			<dt><%= f.label :password, "Current Password" %></dt>
			<dd>
				<%= f.password_field :password, data: { form_validation_target: "field", required: "true", field_name: "Current password" } %>
				<span class="field-error" data-form-validation-target="error" data-for="account_password"></span>
			</dd>
			<dt><%= f.label :new_password, "New Password" %></dt>
			<dd>
				<%= f.password_field :new_password, data: { password_match_target: "password", action: "input->password-match#validate", form_validation_target: "field", required: "true", field_name: "New password" } %>
				<span class="field-error" data-form-validation-target="error" data-for="account_new_password"></span>
			</dd>
			<dt><%= f.label :new_password_confirmation, "Verify new Password" %></dt>
			<dd>
				<%= f.password_field :new_password_confirmation, data: { password_match_target: "confirmation", action: "input->password-match#validate", form_validation_target: "field", required: "true", field_name: "Password confirmation" } %>
				<span class="field-error" data-form-validation-target="error" data-for="account_new_password_confirmation"></span>
				<span class="password-match-message" data-password-match-target="message"></span>
			</dd>
		</dl>
		<%= f.submit "OK", class: "submit_button", data: { password_match_target: "submit", form_validation_target: "submit", loading_text: "Updating..." } %>
	<% end -%>
	</div>
	<div class="clear"></div>
</div>
