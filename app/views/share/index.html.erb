<div id="content"
     data-controller="share"
     data-share-api-key-value="<%= session[:session_id] %>"
     data-share-limit-value="20">
<div class="share">
<h2>Manage Sharing</h2>
<div class="share_body">
	<div class="status">
		<% if current_member.public %>
			<button data-action="click->share#setMemberPublic" data-public-value="0">Disable Sharing</button>
		<% else %>
			<button data-action="click->share#setMemberPublic" data-public-value="1">Enable Sharing</button>
		<% end %>
		<ul>
			<li>Sharing: <span data-share-target="memberPublic"><%= current_member.public ? "ON" : "OFF" %></span>
			<% if current_member.public %>(<%= link_to("Show public subscriptions", user_path(current_member.username)) %>)<% end %>
			</li>
			<li>Public feeds: <span data-share-target="publicCount"></span></li>
		 	<li>Private feeds: <span data-share-target="privateCount"></span></li>
		</ul>
	</div>
	<div class="search_form">
		<form data-action="submit->share#search">
		<table>
			<tr><td>Target</td>
			<td>
				<input type="radio" name="search_from" data-share-target="filterFromAll" data-action="click->share#search" checked>
				<label>All</label>
				<input type="radio" name="search_from" data-share-target="filterFromPublic" data-action="click->share#search">
				<label>Public feeds</label>
				<input type="radio" name="search_from" data-share-target="filterFromPrivate" data-action="click->share#search">
				<label>Private feeds</label>
			</td></tr>
			<tr><td>Subscribers</td>
			<td>
				over <input type="text" value="" data-share-target="filterSubscriberMin" data-action="keyup->share#searchDebounced" size="4"> subscribers and
				under <input type="text" value="" data-share-target="filterSubscriberMax" data-action="keyup->share#searchDebounced" size="4"> subscribers
				(example:
					<span data-action="click->share#setQuery" data-query='{"subscriber_max":"","subscriber_min":100}' class="query_sample">over 100 subscribers</span>
					<span data-action="click->share#setQuery" data-query='{"subscriber_max":10,"subscriber_min":""}' class="query_sample">under 10 subscribers</span>)
			</td></tr>
			<tr><td>Title or URL</td>
			<td><input type="text" value="" data-share-target="filterString" data-action="keyup->share#searchDebounced">
			</td></tr>
		</table>
		<div class="mspace">
		<table>
			<tr>
				<th>Folders (<span class="query_sample" data-action="click->share#resetMspace" data-mspace-type="folder">Select all</span>)</th>
				<th>Ratings (<span class="query_sample" data-action="click->share#resetMspace" data-mspace-type="rate">Select all</span>)</th>
			</tr>
			<tr>
				<td><div data-share-target="mspaceFolders"></div></td>
				<td><div data-share-target="mspaceRate"></div></td>
			</tr>
		</table>
		</div>
		</form>
	</div>
	<h3>Result: <span data-share-target="resultsCount"></span> <button class="select_all" data-action="click->share#selectAll">Select all</button></h3>
	<div class="buttons">
		<button data-action="click->share#setPublic" data-public-value="1">Set to Public</button>
		<button data-action="click->share#setPublic" data-public-value="0">Set to Private</button>
		<span data-share-target="progress"></span>
	</div>
	<div data-share-target="results"></div>
	<span data-share-target="showAll" data-action="click->share#showAll" style="display:none;cursor:pointer;color:#0066cc;text-decoration:underline;">Display all</span>
</div>
</div>
</div>

<%= javascript_importmap_tags %>
